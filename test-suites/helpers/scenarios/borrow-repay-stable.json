{
  "title": "Pool: Borrow/repay stable-rate disabled",
  "description": "Stable-rate borrow and repay are runtime-disabled in Neverland.",
  "stories": [
    {
      "description": "A valid stable borrow reverts with the stable-disabled gate",
      "actions": [
        {
          "name": "mint",
          "args": {
            "reserve": "DAI",
            "amount": "14760.147",
            "user": "0"
          },
          "expected": "success"
        },
        {
          "name": "approve",
          "args": {
            "reserve": "DAI",
            "user": "0"
          },
          "expected": "success"
        },
        {
          "name": "deposit",
          "args": {
            "reserve": "DAI",
            "amount": "14760.147",
            "user": "0"
          },
          "expected": "success"
        },
        {
          "name": "mint",
          "args": {
            "reserve": "WETH",
            "amount": "1",
            "user": "1"
          },
          "expected": "success"
        },
        {
          "name": "approve",
          "args": {
            "reserve": "WETH",
            "user": "1"
          },
          "expected": "success"
        },
        {
          "name": "deposit",
          "args": {
            "reserve": "WETH",
            "amount": "1",
            "user": "1"
          },
          "expected": "success"
        },
        {
          "name": "borrow",
          "args": {
            "reserve": "DAI",
            "amount": "1476.01",
            "borrowRateMode": "stable",
            "user": "1",
            "timeTravel": "365"
          },
          "expected": "revert",
          "revertMessage": "31"
        }
      ]
    },
    {
      "description": "A stable repay request reverts with the stable-disabled gate",
      "actions": [
        {
          "name": "repay",
          "args": {
            "reserve": "DAI",
            "amount": "738",
            "user": "1",
            "onBehalfOf": "1",
            "borrowRateMode": "stable"
          },
          "expected": "revert",
          "revertMessage": "31"
        }
      ]
    },
    {
      "description": "Stable borrow with no collateral still fails before the stable gate",
      "actions": [
        {
          "name": "borrow",
          "args": {
            "reserve": "DAI",
            "amount": "14760.147",
            "borrowRateMode": "stable",
            "user": "2"
          },
          "expected": "revert",
          "revertMessage": "The collateral balance is 0"
        }
      ]
    }
  ]
}
