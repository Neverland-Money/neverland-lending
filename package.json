{
  "name": "@neverland-money/lending-core",
  "version": "1.0.0",
  "description": "Neverland Lending protocol, initially derived 1:1 from @aave/core-v3 v1.19.3",
  "files": [
    "README_UPSTREAM.md",
    "contracts",
    "artifacts",
    "types",
    "dist"
  ],
  "main": "dist/helpers/index.js",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "size": "npm run compile && npm run hardhat size-contracts",
    "run-env": "npm i && tail -f /dev/null",
    "hardhat": "hardhat",
    "compile": "SKIP_LOAD=true hardhat compile",
    "compile:clean": "npm run ci:clean && npm run compile",
    "console:fork": "FORK=main hardhat console",
    "prettier:check": "prettier -c .",
    "prettier:write": "prettier -w .",
    "coverage": ". ./setup-test-env.sh && COVERAGE=true npx hardhat coverage --temp temp-artifacts --testfiles test-suites/emptyrun.coverage.spec.ts && rm -rf coverage.json coverage/ && COVERAGE=true npx hardhat coverage --temp temp-artifacts --testfiles 'test-suites/__setup.spec.ts test-suites/neverland/**/*.spec.ts'",
    "test": "npm run test:neverland",
    "test:prepare": "npm run compile:clean && npm run check:rounding-gates",
    "test:run": ". ./setup-test-env.sh && TS_NODE_TRANSPILE_ONLY=1 hardhat test",
    "test:run:prepared": "SKIP_TEST_SETUP_COMPILE=true npm run test:run --",
    "test:all": "npm run test:prepare && npm run test:protocol:prepared && npm run test:neverland:prepared",
    "test:protocol": "npm run test:prepare && npm run test:protocol:prepared",
    "test:protocol:prepared": "npm run test:run:prepared -- test-suites/*.spec.ts",
    "test:neverland": "npm run test:prepare && npm run test:neverland:prepared",
    "test:neverland:prepared": "npm run test:run:prepared -- test-suites/__setup.spec.ts test-suites/neverland/*.spec.ts test-suites/neverland/rounding-patch/*.spec.ts",
    "test:rounding": "npm run test:prepare && npm run test:rounding:prepared",
    "test:rounding:prepared": "npm run test:run:prepared -- test-suites/__setup.spec.ts test-suites/neverland/rounding-patch/*.spec.ts",
    "test:scenarios": "npm run test:run -- test-suites/__setup.spec.ts test-suites/scenario.spec.ts",
    "test:l2pool": "npm run test:run -- test-suites/__setup.spec.ts test-suites/pool-l2.spec.ts",
    "test:subgraph:scenarios": ". ./setup-test-env.sh && TS_NODE_TRANSPILE_ONLY=1 hardhat --network hardhatevm_docker test test-suites/__setup.spec.ts test-suites/subgraph-scenarios.spec.ts",
    "check:sizes": "TS_NODE_TRANSPILE_ONLY=1 ts-node scripts/rounding/check-sizes.ts",
    "check:selectors": "TS_NODE_TRANSPILE_ONLY=1 ts-node scripts/rounding/check-selectors.ts",
    "check:live-assumptions": "TS_NODE_TRANSPILE_ONLY=1 hardhat run scripts/rounding/check-live-assumptions.ts",
    "check:rounding-gates": "npm run check:sizes && npm run check:selectors",
    "ci:test": "npm run test",
    "ci:clean": "rm -rf ./artifacts ./cache ./types ./temp-artifacts ./dist",
    "hooks:install": "husky install",
    "build": "tsc --project lib.tsconfig.json",
    "prepublish": "npm run compile && npm run build"
  },
  "devDependencies": {
    "@aave/core-v3": "1.19.3",
    "@aave/deploy-v3": "1.56.2",
    "@aave/periphery-v3": "2.5.2",
    "@ethersproject/bignumber": "5.8.0",
    "@nomicfoundation/hardhat-chai-matchers": "1.0.5",
    "@nomicfoundation/hardhat-toolbox": "2.0.2",
    "@tenderly/hardhat-tenderly": "1.1.0-beta.5",
    "@types/chai": "4.3.20",
    "@types/lowdb": "1.0.15",
    "@types/node": "22.19.19",
    "bluebird": "^3.7.2",
    "dotenv": "16.6.1",
    "eth-sig-util": "3.0.1",
    "ethereumjs-util": "7.1.5",
    "hardhat": "2.26.3",
    "hardhat-contract-sizer": "2.10.1",
    "hardhat-dependency-compiler": "1.2.1",
    "hardhat-deploy": "0.11.45",
    "husky": "8.0.3",
    "jsondiffpatch": "0.4.1",
    "lint-staged": "13.1.0",
    "prettier": "2.8.4",
    "prettier-plugin-solidity": "1.1.3",
    "ts-node": "10.9.2",
    "tslint": "6.1.2",
    "tslint-config-prettier": "1.18.0",
    "tslint-plugin-prettier": "2.3.0",
    "typescript": "4.9.5"
  },
  "author": "Neverland",
  "contributors": [
    "Emilio Frangella <emilio@aave.com>",
    "Miguel Martinez <miguel@aave.com>",
    "Steven Valeri <steven@aave.com>",
    "David Racero <david.k@aave.com>",
    "Lasse Herskind <lasse@aave.com>",
    "Mark Hinschberger <mark@aave.com>",
    "Peter Michael <peter.dev@aave.com>",
    "Pol Sendra <pol@aave.com>",
    "Catalyst <catalyst@neverland.money>"
  ],
  "license": "BUSL-1.1",
  "keywords": [
    "neverland",
    "monad",
    "solidity"
  ],
  "upstream": {
    "name": "@aave/core-v3",
    "version": "1.19.3",
    "repository": "https://github.com/aave/aave-v3-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neverland-Money/neverland-lending.git"
  },
  "homepage": "https://github.com/Neverland-Money/neverland-lending#readme",
  "lint-staged": {
    "*.{ts,js,md,sol}": "prettier --write"
  }
}
